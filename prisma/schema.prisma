generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model RSVP {
  id                 Int      @id @default(autoincrement())
  nomeCompleto       String
  numeroAcompanhantes Int
  telefone           String
  dataConfirmacao    DateTime @default(now())
}

model Gift {
  id               Int      @id @default(autoincrement())
  name             String
  category         String   @default("Cozinha")
  price            Float?
  productUrl       String?
  isGiven          Boolean  @default(false)
  giverName        String?
  giverMessage     String?
  givenAt          DateTime?
}
