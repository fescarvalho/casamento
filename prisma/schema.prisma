generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model RSVP {
  id                 Int      @id @default(autoincrement())
  nomeCompleto       String
  numeroAcompanhantes Int      @default(0)
  nomesAcompanhantes  String?
  telefone           String?
  dataConfirmacao    DateTime @default(now())
}

model Gift {
  id               Int      @id @default(autoincrement())
  name             String
  category         String   @default("Cozinha")
  price            Float?
  productUrl       String?
  isGiven          Boolean  @default(false)
  giverName        String?
  giverMessage     String?
  givenAt          DateTime?
}

model Guest {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  isInvited     Boolean @default(true)
  maxCompanions Int     @default(0)
}
